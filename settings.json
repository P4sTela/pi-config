{
  "lastChangelogVersion": "0.81.1",
  "theme": "dark",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-luna",
  "defaultThinkingLevel": "high",
  "enabledModels": [
    "deepseek-v4-pro",
    "deepseek-v4-flash",
    "kimi-k2.7-code",
    "glm-5.2",
    "qwen3.7-max",
    "rglm/glm-5.2",
    "rglm/glm-4.5-flash",
    "gpt-5.6-*"
  ],
  "subagents": {
    "defaultModel": "openai-codex/gpt-5.6-luna",
    "agentOverrides": {
      "scout": {
        "model": "openai-codex/gpt-5.6-luna",
        "thinking": "low",
        "fallbackModels": [
          "opencode-go/kimi-k2.7-code"
        ]
      },
      "researcher": {
        "model": "openai-codex/gpt-5.6-luna",
        "thinking": "medium",
        "fallbackModels": [
          "opencode-go/kimi-k2.7-code"
        ]
      },
      "delegate": {
        "model": "openai-codex/gpt-5.6-luna",
        "thinking": "low",
        "fallbackModels": [
          "opencode-go/kimi-k2.7-code"
        ]
      },
      "context-builder": {
        "model": "openai-codex/gpt-5.6-terra",
        "fallbackModels": [
          "opencode-go/kimi-k2.7-code"
        ]
      },
      "planner": {
        "model": "openai-codex/gpt-5.6-terra",
        "fallbackModels": [
          "opencode-go/kimi-k2.7-code"
        ]
      },
      "oracle": {
        "model": "openai-codex/gpt-5.6-terra",
        "fallbackModels": [
          "opencode-go/kimi-k2.7-code"
        ]
      },
      "reviewer": {
        "model": "openai-codex/gpt-5.6-terra",
        "fallbackModels": [
          "opencode-go/kimi-k2.7-code"
        ]
      },
      "worker": {
        "model": "openai-codex/gpt-5.6-terra",
        "fallbackModels": [
          "opencode-go/kimi-k2.7-code"
        ]
      }
    }
  },
  "shellCommandPrefix": "export PATH=\"$HOME/.pi/agent/npm/node_modules/.bin:$PATH\"",
  "packages": [
    "npm:@hypabolic/pi-hypa",
    "npm:pi-web-access",
    "npm:pi-lens",
    "npm:pi-subagents"
  ]
}